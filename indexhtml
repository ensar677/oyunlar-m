#enterPrompt{position:fixed;bottom:160px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.82);border:1px solid rgba(245,166,35,0.55);color:#f5a623;padding:7px 22px;font-size:11px;letter-spacing:2px;display:none;z-index:60;pointer-events:none;}
</style>
