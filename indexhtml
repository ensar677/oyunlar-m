#inventoryPanel{position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:200;display:none;align-items:center;justify-content:center;}
.invBox{background:#111;border:1px solid rgba(245,166,35,0.4);width:740px;max-height:88vh;overflow-y:auto;padding:22px;}
