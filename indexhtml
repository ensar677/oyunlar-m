function doP2Shoot(){
  if(P2.isReloading||p2ShootCD>0||P2.dead)return;
  if(P2.ammo<=0){if(P2.reserve>0){P2.isReloading=true;P2.reloadTimer=0;sndReload();}return;}
  P2.ammo--;p2ShootCD=0.11;updateP2HUD();
  fireP2Bullet();sndGunshot();
}

function updateP2(dt){
  if(GAME_MODE!==2||P2.dead)return;
  var fwd=0,str=0;
  if(P2_KEYS['KeyI'])fwd=4.5*dt;
  if(P2_KEYS['KeyK'])fwd=-4.5*dt;
  if(P2_KEYS['KeyJ']){str=-4.5*dt;P2.yaw-=0.045;}
  if(P2_KEYS['KeyL']){str=4.5*dt;P2.yaw+=0.045;}
  var c=Math.cos(P2.yaw),s=Math.sin(P2.yaw);
  var nx=P2.x-s*fwd+c*str, nz=P2.z-c*fwd-s*str;
  if(!solidAt(nx,P2.z))P2.x=Math.max(-230,Math.min(230,nx));
  if(!solidAt(P2.x,nz))P2.z=Math.max(-230,Math.min(230,nz));
  P2.y=gY(P2.x,P2.z);
  if(p2Model){p2Model.position.set(P2.x,P2.y,P2.z);p2Model.rotation.y=P2.yaw;}
  p2ShootCD=Math.max(0,p2ShootCD-dt);
  if(P2_KEYS['KeyN'])doP2Shoot();
  if(P2.isReloading){P2.reloadTimer+=dt*1000;if(P2.reloadTimer>=2200){var need=P2.maxAmmo-P2.ammo,take=Math.min(need,P2.reserve);P2.ammo+=take;P2.reserve-=take;P2.isReloading=false;updateP2HUD();}}
  // Bölge hasarı P2'ye de
  var d2=Math.sqrt(P2.x*P2.x+P2.z*P2.z);
  if(d2>G.zoneRadius){P2.health=Math.max(0,P2.health-dt*3);updateP2HUD();if(P2.health<=0&&!P2.dead){P2.dead=true;addKF('💀 P2 bölge dışında öldü!','#88aaff');if(p2Model)scene.remove(p2Model);}}
}

function triggerDeath(){G.dead=true;document.exitPointerLock();sndDeath();var t=Math.floor((Date.now()-G.startTime)/1000);document.getElementById('gameOverScreen').style.display='flex';document.getElementById('goStats').innerHTML='Oldurme: '+G.kills+' | Hasar: '+G.totalDamage+'<br>Sure: '+t+'s | Hayatta Kalan: '+G.alive;}
function triggerWin(){if(G.dead||G.won)return;G.won=true;document.exitPointerLock();sndWin();var t=Math.floor((Date.now()-G.startTime)/1000);document.getElementById('winScreen').style.display='flex';document.getElementById('winStats').innerHTML='Oldurme: '+G.kills+' | Hasar: '+G.totalDamage+'<br>Sure: '+t+'s | Kalan Can: '+Math.ceil(G.health);}

// ========== ANA DÖNGÜ ==========
function loop(ts){
  requestAnimationFrame(loop);
  if(!G.gameStarted||G.dead||G.won){renderer.render(scene,camera);return;}
  var dt=Math.min((ts-lastTS)/1000,0.05);lastTS=ts;

  if(!G.invOpen&&!G.emojiOpen&&document.pointerLockElement){
    yaw-=MOUSE.dx*0.002;
    pitch=Math.max(-Math.PI/2.1,Math.min(Math.PI/2.1,pitch+MOUSE.dy*0.002));
  }
  MOUSE.dx=0;MOUSE.dy=0;

  pivot.rotation.y=yaw;
  camera.rotation.order='YXZ';camera.rotation.y=0;
  camera.rotation.x=G.camMode==='first'?-pitch:-pitch*0.5-0.15;

  if(!G.invOpen&&!G.emojiOpen){
    var run=KEYS['ShiftLeft']||KEYS['ShiftRight'];
    var spd=(run?8:4.5)*dt;
    var mfwd=0,mstr=0;

    // DÜZELTILMIŞ KONTROLLER: W=ileri, S=geri
    if(KEYS['KeyW']||KEYS['ArrowUp'])   mfwd= spd;
    if(KEYS['KeyS']||KEYS['ArrowDown']) mfwd=-spd;
    if(KEYS['KeyA']||KEYS['ArrowLeft']) mstr=-spd;
    if(KEYS['KeyD']||KEYS['ArrowRight'])mstr= spd;

    var cosY=Math.cos(yaw),sinY=Math.sin(yaw);
    // İleri = kameranın baktığı yön (negatif Z ekseninde)
    var nx=pivot.position.x - sinY*mfwd + cosY*mstr;
    var nz=pivot.position.z - cosY*mfwd - sinY*mstr;

    var BOUND=230;
    if(!solidAt(nx,pivot.position.z))pivot.position.x=Math.max(-BOUND,Math.min(BOUND,nx));
    if(!solidAt(pivot.position.x,nz))pivot.position.z=Math.max(-BOUND,Math.min(BOUND,nz));

    velY-=22*dt;pivot.position.y+=velY*dt;
    var groundH=gY(pivot.position.x,pivot.position.z);
    if(pivot.position.y<=groundH){
      if(!prevOnGround)sndLand();
      pivot.position.y=groundH;velY=0;onGround=true;
    }else onGround=false;

    if(KEYS['Space']&&onGround){velY=7.5;onGround=false;sndJump();}

    // Ayak sesleri
    if((mfwd!==0||mstr!==0)&&onGround){
      footTimer-=dt;
      if(footTimer<=0){sndFootstep(run);footTimer=run?0.24:0.38;}
    }

    prevOnGround=onGround;
    if(playerModel){playerModel.position.copy(pivot.position);playerModel.rotation.y=yaw;}
    if((mfwd!==0||mstr!==0)&&onGround&&weaponGroup){bobT+=dt*(run?12:7);var ba=run?0.055:0.025;weaponGroup.position.y=-0.26+Math.sin(bobT)*ba;weaponGroup.position.x=0.22+Math.sin(bobT*0.5)*ba*0.5;}

    if(MOUSE.btn[0])doShoot();
    shootCD=Math.max(0,shootCD-dt);
    if(MOUSE.btn[2]&&!G.isScoped)setScope(true);
    if(!MOUSE.btn[2]&&G.isScoped)setScope(false);

    if(G.isReloading){reloadTimer+=dt*1000;if(reloadTimer>=RELOAD_MS)finishReload();}
    if(muzzleT>0){muzzleT-=dt;if(muzzleT<=0&&muzzleFlashMesh)muzzleFlashMesh.material.opacity=0;}
    if(hitT>0){hitT-=dt;if(hitT<=0)document.getElementById('hitMark').style.opacity='0';}

    dmgAlpha=Math.max(0,dmgAlpha-dt*2.5);
    document.getElementById('dmgVignette').style.background='radial-gradient(ellipse at center, transparent 40%, rgba(255,0,0,'+dmgAlpha*0.85+') 100%)';

    checkNearDrop();
    if(KEYS['KeyF']&&G.nearBuilding&&!G.insideBuilding){
      // Binaya gir: kapıya doğru ilerlet
      pivot.position.x=G.nearBuilding.x;pivot.position.z=G.nearBuilding.z;
      KEYS['KeyF']=false;
    } else if(KEYS['KeyF']&&G.nearDrop){collectDrop(G.nearDrop);KEYS['KeyF']=false;}
  }

  updateEnemies(dt);updateBullets(dt);updateParticles(dt);updateZone(dt);updateMinimap();if(GAME_MODE===2)updateP2(dt);
  if(G.health<G.maxHealth&&G.health>0){G.health=Math.min(G.maxHealth,G.health+dt*0.4);updateHealthHUD();}
  renderer.render(scene,camera);
}

document.addEventListener('keydown',function(e){
  // P2 tuşları
  if(['KeyI','KeyJ','KeyK','KeyL','KeyN','KeyU','KeyP'].indexOf(e.code)!==-1){P2_KEYS[e.code]=true;}
});
document.addEventListener('keyup',function(e){
  if(['KeyI','KeyJ','KeyK','KeyL','KeyN','KeyU','KeyP'].indexOf(e.code)!==-1){P2_KEYS[e.code]=false;}
});
document.addEventListener('keydown',function(e){
  resumeAC();
  KEYS[e.code]=true;
  if(planePhase==='flying'&&e.code==='Space'){doJumpFromPlane();e.preventDefault();return;}
  if(!G.gameStarted)return;
  if(e.code==='KeyR'&&!G.isReloading)startReload();
  if(e.code==='KeyV')toggleCam();
  if(e.code==='Tab'||e.code==='KeyI'){e.preventDefault();G.invOpen?closeInv():openInv();return;}
  if(e.code==='KeyZ')toggleEmojiPanel();
  if(e.code==='Escape'){if(G.invOpen)closeInv();if(G.emojiOpen){G.emojiOpen=false;document.getElementById('emojiPanel').style.display='none';renderer.domElement.requestPointerLock();}}
  e.preventDefault();
});
document.addEventListener('keyup',function(e){KEYS[e.code]=false;});
document.addEventListener('mousemove',function(e){if(document.pointerLockElement){MOUSE.dx+=e.movementX;MOUSE.dy+=e.movementY;}});
document.addEventListener('mousedown',function(e){resumeAC();MOUSE.btn[e.button]=true;e.preventDefault();});
document.addEventListener('mouseup',function(e){MOUSE.btn[e.button]=false;});
document.addEventListener('contextmenu',function(e){e.preventDefault();});
renderer.domElement.addEventListener('click',function(){if(G.gameStarted&&!G.dead&&!G.won&&!G.invOpen&&!G.emojiOpen)renderer.domElement.requestPointerLock();});
window.addEventListener('resize',function(){camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);if(planeCanvas){planeCanvas.width=window.innerWidth;planeCanvas.height=window.innerHeight;}});

function startGame(){
  resumeAC();
  document.getElementById('startScreen').style.display='none';
  mmCtx=document.getElementById('minimapCanvas').getContext('2d');
  var botCount = (GAME_MODE===2)?49:19;
  var totalAlive = botCount+1+(GAME_MODE===2?1:0);
  G.alive=totalAlive;
  buildWorld();spawnEnemies(botCount);createPlayerModel();setCamMode('first');makeZoneRing();
  var dropCount=(GAME_MODE===2)?24:14;
  for(var i=0;i<dropCount;i++){var a=Math.random()*Math.PI*2,r=12+Math.random()*100;spawnDrop(Math.cos(a)*r,Math.sin(a)*r,false);}
  if(GAME_MODE===2){
    createP2Model();
    document.getElementById('p2hud').style.display='block';
    document.getElementById('p2ammoWrap').style.display='block';
    document.getElementById('p2label').style.display='block';
    updateP2HUD();
  }
  updateHealthHUD();updateShieldHUD();updateAmmoHUD();updateAliveHUD();
  startPlaneSequence();
  requestAnimationFrame(loop);
}

function launchGame(){
  // Uçak bittikten sonra gerçek oyunu aç
  G.gameStarted=true;G.startTime=Date.now();lastTS=performance.now();
  document.getElementById('crosshair').style.display='block';
  document.getElementById('camModeLabel').style.display='block';
  document.getElementById('emojiBtn').style.display='flex';
  renderer.domElement.requestPointerLock();
  setTimeout(function(){if(!G.dead&&!G.won)spawnAirdrop();},22000);
  setInterval(function(){if(!G.dead&&!G.won)spawnAirdrop();},50000);
}

renderer.render(scene,camera);
</script>
</body>
</html>
