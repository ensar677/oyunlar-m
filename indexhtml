function collectDrop(drop){
  if(drop.collected)return;drop.collected=true;
  scene.remove(drop.mesh);scene.remove(drop.ring);
  drop.items.forEach(function(item){
    if(item.type==='med'){
      if(item.heal>0){G.health=Math.min(G.maxHealth,G.health+item.heal);updateHealthHUD();}
      if(item.shield>0){G.shield=Math.min(G.maxShield,G.shield+item.shield);updateShieldHUD();}
      inv.meds.push(Object.assign({},item));
    }else if(item.type==='armor'){
      if(item.level>G.armorLevel){G.armorLevel=item.level;G.shield=Math.min(G.maxShield,G.shield+30*item.level);updateShieldHUD();}
      inv.items.push(Object.assign({},item));
    }else if(item.type==='ammo'){
      G.reserve=Math.min(300,G.reserve+(item.amount||60));updateAmmoHUD();inv.items.push(Object.assign({},item));
    }else{inv.items.push(Object.assign({},item));}
    showPickup(item.emoji+' '+item.name+' toplandi!');sndPickup();
  });
  drops=drops.filter(function(d){return !d.collected;});
}

