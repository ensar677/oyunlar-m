function updateEnemies(dt){
  var px=pivot.position.x,pz=pivot.position.z;
  enemies.forEach(function(e,idx){
    if(!e.alive)return;
    e.nMesh.quaternion.copy(camera.quaternion);
    e.hbMesh.quaternion.copy(camera.quaternion);

    var dx=px-e.x,dz=pz-e.z;
    var distPlayer=Math.sqrt(dx*dx+dz*dz);

    // ==== BOT-BOT ÇATIŞMA SİSTEMİ ====
    // En yakın canlı botu bul
    var nearestBot=null,nearestDist=e.botAggroRange;
    enemies.forEach(function(other,oidx){
      if(oidx===idx||!other.alive)return;
      var odx=other.x-e.x,odz=other.z-e.z;
      var od=Math.sqrt(odx*odx+odz*odz);
      if(od<nearestDist){nearestDist=od;nearestBot=other;}
    });

    // Oyuncu daha yakınsa ona odaklan
    var target=null,targetDist=Infinity;
    if(distPlayer<80){target='player';targetDist=distPlayer;}
    if(nearestBot&&nearestDist<targetDist){target='bot';targetDist=nearestDist;}

    if(target==='player'){
      // Oyuncuya hareket et
      e.mesh.rotation.y=Math.atan2(dx,dz);
      var spd=e.speed*dt*(distPlayer<6?0.3:1);
      if(distPlayer>3){
        var tx=e.x+(dx/distPlayer)*spd,tz=e.z+(dz/distPlayer)*spd;
        if(!solidAt(tx,e.z,0.35))e.x=tx;
        if(!solidAt(e.x,tz,0.35))e.z=tz;
      }
      e.ey=gY(e.x,e.z);e.mesh.position.set(e.x,e.ey,e.z);
      // Oyuncuya ateş et
      e.shootTimer-=dt;e.shootCD-=dt;
      if(distPlayer<32&&e.shootTimer<=0&&e.shootCD<=0){
        e.shootCD=0.55;e.shootTimer=2.5+Math.random()*2;
        fireEnemyBullet(e.x,e.ey,e.z,px,pivot.position.y,pz);sndGunshot();
      }
    } else if(target==='bot'&&nearestBot){
      // Bota hareket et
      var bdx=nearestBot.x-e.x,bdz=nearestBot.z-e.z;
      var bd=Math.sqrt(bdx*bdx+bdz*bdz);
      e.mesh.rotation.y=Math.atan2(bdx,bdz);
      var bspd=e.speed*dt*(bd<5?0.2:1);
      if(bd>4){
        var btx=e.x+(bdx/bd)*bspd,btz=e.z+(bdz/bd)*bspd;
        if(!solidAt(btx,e.z,0.35))e.x=btx;
        if(!solidAt(e.x,btz,0.35))e.z=btz;
      }
      e.ey=gY(e.x,e.z);e.mesh.position.set(e.x,e.ey,e.z);
      // Bota ateş et
      e.botShootTimer-=dt;e.botShootCD-=dt;
      if(bd<35&&e.botShootTimer<=0&&e.botShootCD<=0){
        e.botShootCD=0.6;e.botShootTimer=2+Math.random()*3;
        var dmg=18+Math.floor(Math.random()*12);
        nearestBot.health-=dmg;
        spawnParticles(new THREE.Vector3(nearestBot.x,nearestBot.ey+1.2,nearestBot.z),0xff2222,4);
        drawEHP(nearestBot);
        if(nearestBot.health<=0){
          // Bot öldürdü botu
          addKF('💀 '+e.name+' → '+nearestBot.name,'#ff8800');
          killBotByBot(nearestBot);
        }
      }
    } else {
      // Rastgele dolaş
      e.wTimer-=dt;
      if(e.wTimer<=0){e.wAngle+=(-1+Math.random()*2)*1.2;e.wTimer=2+Math.random()*3;}
      var ws=1.0*dt;
      var wx=e.x+Math.cos(e.wAngle)*ws,wz=e.z+Math.sin(e.wAngle)*ws;
      if(!solidAt(wx,e.z,0.35))e.x=wx;
      if(!solidAt(e.x,wz,0.35))e.z=wz;
      e.ey=gY(e.x,e.z);e.mesh.position.set(e.x,e.ey,e.z);
    }
  });
}

function killBotByBot(e){
  if(!e.alive)return;
  e.alive=false;G.alive--;
  scene.remove(e.mesh);
  spawnParticles(new THREE.Vector3(e.x,e.ey+1,e.z),0xff3333,12);
