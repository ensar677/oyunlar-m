var planeCanvas=null,planeCtx=null,planeX=0,planeT=0;
var freefallNode=null,freefallActive=false;
var planePhase='idle'; // 'flying','freefall','landing','done'
var freefallY=800, freefallVY=0;
var playerSpawnX=0,playerSpawnZ=0;

function startPlaneSequence(){
  planeCanvas=document.getElementById('planeCanvas');
  planeCanvas.width=window.innerWidth;planeCanvas.height=window.innerHeight;
  planeCtx=planeCanvas.getContext('2d');
  document.getElementById('planeScreen').style.display='flex';
  planeX=-150;planeT=0;planePhase='flying';
  freefallY=800;freefallVY=0;
  // Uçak spawn konumu
  playerSpawnX=(Math.random()-0.5)*80;
  playerSpawnZ=(Math.random()-0.5)*80;
  sndPlaneEngine();
  addKF('✈️  Ucak giriyor! SPACE ile atla','#f5a623');
  animatePlane();
}

function animatePlane(ts){
  if(planePhase==='done')return;
  requestAnimationFrame(animatePlane);
  planeCtx.clearRect(0,0,planeCanvas.width,planeCanvas.height);
  var W=planeCanvas.width,H=planeCanvas.height;

  if(planePhase==='flying'){
    planeX+=3.5;
    var pct=Math.min(planeX/(W+200),1);
    // Gökyüzü gradyanı
    var sky=planeCtx.createLinearGradient(0,0,0,H);
    sky.addColorStop(0,'#1a3a6e');sky.addColorStop(0.5,'#2a6ab0');sky.addColorStop(1,'#87CEEB');
    planeCtx.fillStyle=sky;planeCtx.fillRect(0,0,W,H);
    // Bulutlar
    planeCtx.fillStyle='rgba(255,255,255,0.7)';
    [[W*0.2,H*0.25,80],[W*0.5,H*0.18,60],[W*0.75,H*0.3,90],[W*0.35,H*0.4,50]].forEach(function(c){
      planeCtx.beginPath();planeCtx.ellipse(c[0],c[1],c[2],c[2]*0.45,0,0,Math.PI*2);planeCtx.fill();
    });
    // Yükseklik göstergesi
    document.getElementById('planeAltFill').style.height=(100*(1-pct))+'%';
    // Uçağı çiz
    drawPlane(planeCtx,planeX,H*0.32);
    // Oyuncunun konumunu oka göster
    planeCtx.fillStyle='rgba(245,166,35,0.85)';
    planeCtx.font='bold 13px Courier New';
    planeCtx.textAlign='center';
    planeCtx.fillText('SEN',planeX,H*0.32-52);
    // Otomatik atlama — uçak ortadan geçince
    if(planeX>W*0.45&&planeX<W*0.7&&KEYS['Space']){
      doJumpFromPlane();
    }
    if(planeX>W+200){
      // Zorla atla
      doJumpFromPlane();
    }
  } else if(planePhase==='freefall'){
    freefallVY+=18; // yerçekimi
    freefallY-=freefallVY*0.06;
    var pct2=Math.max(0,Math.min(1,freefallY/800));
    // Giderek yaklaşan zemin görünümü
    var sky2=planeCtx.createLinearGradient(0,0,0,H);
    sky2.addColorStop(0,'#87CEEB');sky2.addColorStop(0.6,'#aadcaa');sky2.addColorStop(1,'#4a7a3a');
    planeCtx.fillStyle=sky2;planeCtx.fillRect(0,0,W,H);
    // Zemin grid - yaklaşırken büyüyen kareler
    var gridScale=1+Math.pow(1-pct2,2)*8;
    planeCtx.strokeStyle='rgba(0,150,0,0.3)';planeCtx.lineWidth=1;
    var gSize=40*gridScale;
    for(var gx=0;gx<W;gx+=gSize){planeCtx.beginPath();planeCtx.moveTo(gx,0);planeCtx.lineTo(gx,H);planeCtx.stroke();}
    for(var gy=0;gy<H;gy+=gSize){planeCtx.beginPath();planeCtx.moveTo(0,gy);planeCtx.lineTo(W,gy);planeCtx.stroke();}
    // İrtifa barı
    document.getElementById('planeAltFill').style.height=(freefallY/800*100)+'%';
    // Hız göstergesi
    planeCtx.fillStyle='rgba(0,0,0,0.5)';planeCtx.fillRect(W/2-80,H-90,160,35);
    planeCtx.fillStyle='#f5a623';planeCtx.font='bold 12px Courier New';planeCtx.textAlign='center';
    planeCtx.fillText('HIZ: '+(freefallVY*12|0)+' km/h',W/2,H-66);
    // Paraşüt ikon
    planeCtx.font='50px sans-serif';planeCtx.textAlign='center';
    planeCtx.fillText('🪂',W/2,H/2+(1-pct2)*30);
    // Yere yaklaşınca otomatik iniş
    if(freefallY<=60){
      doLandFromFreefall();
    }
  }
}

function drawPlane(ctx,x,y){
  ctx.save();ctx.translate(x,y);
  // Gövde
  ctx.fillStyle='#e8e8e8';ctx.beginPath();ctx.ellipse(0,0,70,18,0,0,Math.PI*2);ctx.fill();
  // Kanatlar
  ctx.fillStyle='#cccccc';ctx.beginPath();ctx.moveTo(-10,-5);ctx.lineTo(20,-5);ctx.lineTo(30,-30);ctx.lineTo(-30,-28);ctx.closePath();ctx.fill();
  ctx.beginPath();ctx.moveTo(-10,5);ctx.lineTo(10,5);ctx.lineTo(15,22);ctx.lineTo(-15,22);ctx.closePath();ctx.fill();
  // Kuyruk
  ctx.fillStyle='#bbbbbb';ctx.beginPath();ctx.moveTo(55,0);ctx.lineTo(75,-18);ctx.lineTo(75,0);ctx.closePath();ctx.fill();
  // Motorlar
  ctx.fillStyle='#888';ctx.beginPath();ctx.ellipse(-15,-5,14,6,0,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(10,-5,12,5,0,0,Math.PI*2);ctx.fill();
  // Motor alevi
  ctx.fillStyle='rgba(255,140,0,0.8)';ctx.beginPath();ctx.ellipse(-27,-5,6,3,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='rgba(255,200,0,0.6)';ctx.beginPath();ctx.ellipse(-22,-5,3,2,0,0,Math.PI*2);ctx.fill();
  ctx.restore();
}

function doJumpFromPlane(){
  if(planePhase!=='flying')return;
  planePhase='freefall';
  document.getElementById('jumpPrompt').style.display='none';
  document.getElementById('freefallHUD').style.display='block';
  freefallNode=sndFreefall();
  addKF('⬇️  Serbest düşüş!','#44aaff');
}

function doLandFromFreefall(){
  if(planePhase!=='freefall')return;
  planePhase='done';
  if(freefallNode){try{freefallNode.src.stop();}catch(e){}}
  document.getElementById('planeScreen').style.display='none';
  document.getElementById('freefallHUD').style.display='none';
  sndLand();
  // Oyuncuyu spawn pozisyonuna yerleştir
  pivot.position.set(playerSpawnX,gY(playerSpawnX,playerSpawnZ)+1,playerSpawnZ);
  velY=-2;
  addKF('🪂  Indis! Hazirsin.','#44ff88');
  // Gerçek oyunu başlat
  launchGame();
}

