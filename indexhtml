function solidAt(x,z,r){
  r=r||0.5;
  for(var i=0;i<obstacles.length;i++){
    var o=obstacles[i];
    if(Math.abs(x-o.x)<o.hw+r&&Math.abs(z-o.z)<o.hd+r){
      if(o.isDoor){
        // Kapı açıklığından geç (ön kapı merkezi)
        if(Math.abs(x-o.doorX)<(o.doorW/2+r)&&Math.abs(z-o.doorZ)<(1.5+r)) return false;
      }
      return true;
    }
  }
  return false;
}

function buildGround(){
  var geo=new THREE.PlaneGeometry(600,600,50,50);
  var pos=geo.attributes.position;
