<script>
// ========== OYUN MODU ==========
var GAME_MODE = 1;
function selectMode(m){
  GAME_MODE=m;
  document.getElementById('mode1').classList.toggle('active',m===1);
  document.getElementById('mode2').classList.toggle('active',m===2);
  document.getElementById('p2controls').style.display=m===2?'block':'none';
}

// ========== SES SİSTEMİ ==========
var AC=null;
function getAC(){if(!AC){try{AC=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}return AC;}
function resumeAC(){var ac=getAC();if(ac&&ac.state==='suspended')ac.resume();}

function sndGunshot(){
  var ac=getAC();if(!ac)return;
  var t=ac.currentTime;
  // Patlama gürültüsü
  var sz=ac.sampleRate*0.15;var buf=ac.createBuffer(1,sz,ac.sampleRate);
  var d=buf.getChannelData(0);
  for(var i=0;i<sz;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/sz,1.5);
  var src=ac.createBufferSource();src.buffer=buf;
  var bp=ac.createBiquadFilter();bp.type='bandpass';bp.frequency.value=250;bp.Q.value=0.6;
  var g=ac.createGain();g.gain.setValueAtTime(2.5,t);g.gain.exponentialRampToValueAtTime(0.001,t+0.15);
