.eopt{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);font-size:20px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;cursor:pointer;border-radius:3px;transition:all 0.1s;}
