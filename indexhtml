  bullets.push({mesh:m,dir:dir.clone(),dist:0,max:80,alive:true,isEnemy:true});
}

function fireBullet(){
  var dir=new THREE.Vector3();camera.getWorldDirection(dir);
  var orig=new THREE.Vector3();camera.getWorldPosition(orig);
  orig.addScaledVector(dir,0.5);
  var m=new THREE.Mesh(bGeo0,bMat0.clone());m.position.copy(orig);scene.add(m);
  bullets.push({mesh:m,dir:dir.clone(),dist:0,max:220,alive:true,isEnemy:false});
}

function fireP2Bullet(){
  var dir=new THREE.Vector3(Math.sin(P2.yaw),0,-Math.cos(P2.yaw));
  var orig=new THREE.Vector3(P2.x,P2.y+1.4,P2.z);
  orig.addScaledVector(dir,0.5);
  var m=new THREE.Mesh(bGeo0,new THREE.MeshBasicMaterial({color:0x44aaff}));
  m.position.copy(orig);scene.add(m);
  bullets.push({mesh:m,dir:dir.clone(),dist:0,max:180,alive:true,isEnemy:false});
}

function updateBullets(dt){
  bullets.forEach(function(b){
    if(!b.alive)return;
    b.mesh.position.addScaledVector(b.dir,95*dt);b.dist+=95*dt;
    if(b.dist>b.max){killBullet(b);return;}
    var bx=b.mesh.position.x,bz=b.mesh.position.z,by=b.mesh.position.y;
    if(b.isEnemy){
      // Oyuncu 1'e çarpsın
      var pdx=bx-pivot.position.x,pdz=bz-pivot.position.z,pdy=by-(pivot.position.y+1.2);
      if(Math.sqrt(pdx*pdx+pdy*pdy+pdz*pdz)<0.9&&!G.dead){
        playerHit(6+Math.floor(Math.random()*8));spawnParticles(b.mesh.position.clone(),0xff8800,3);killBullet(b);return;
      }
      // Oyuncu 2'ye çarpsın
      if(GAME_MODE===2&&!P2.dead){
        var p2dx=bx-P2.x,p2dz=bz-P2.z,p2dy=by-(P2.y+1.2);
        if(Math.sqrt(p2dx*p2dx+p2dy*p2dy+p2dz*p2dz)<0.9){
          p2Hit(6+Math.floor(Math.random()*8));spawnParticles(b.mesh.position.clone(),0xff8800,3);killBullet(b);return;
        }
      }
    } else {
      enemies.forEach(function(e){
        if(!e.alive||!b.alive)return;
        var ex=bx-e.x,ez=bz-e.z,ey=by-(e.ey+1.2);
        if(Math.sqrt(ex*ex+ey*ey+ez*ez)<0.8){
          var dmg=22+Math.floor(Math.random()*12);e.health-=dmg;G.totalDamage+=dmg;
          showHitMark();sndHit();spawnParticles(b.mesh.position.clone(),0xff2222,6);drawEHP(e);
          if(e.health<=0)killEnemy(e);
          killBullet(b);
        }
      });
    }
    if(!b.alive)return;
    if(solidAt(bx,bz,0.05)){spawnParticles(b.mesh.position.clone(),0xbbbbbb,4);killBullet(b);}
    else if(by<=gY(bx,bz)){spawnParticles(b.mesh.position.clone(),0x888844,4);killBullet(b);}
  });
  bullets=bullets.filter(function(b){return b.alive;});
}
function killBullet(b){scene.remove(b.mesh);b.alive=false;}

function spawnParticles(pos,color,n){
  for(var i=0;i<n;i++){
    var m=new THREE.Mesh(new THREE.SphereGeometry(0.04,3,3),new THREE.MeshBasicMaterial({color:color,transparent:true,opacity:1}));
    m.position.copy(pos);scene.add(m);
    particles.push({mesh:m,vel:new THREE.Vector3((Math.random()-0.5)*9,Math.random()*6,(Math.random()-0.5)*9),life:0.6,alive:true});
  }
}
function updateParticles(dt){
  particles.forEach(function(p){
    if(!p.alive)return;
    p.mesh.position.addScaledVector(p.vel,dt);p.vel.y-=18*dt;p.life-=dt;
    p.mesh.material.opacity=Math.max(0,p.life/0.6);
    if(p.life<=0){scene.remove(p.mesh);p.alive=false;}
  });
  particles=particles.filter(function(p){return p.alive;});
}

function playerHit(amt){
  if(G.dead||G.won)return;
  var rem=amt;
  if(G.shield>0){var sd=Math.min(rem,G.shield);G.shield-=sd;rem-=sd;updateShieldHUD();}
  if(rem>0){G.health=Math.max(0,G.health-rem);updateHealthHUD();}
  dmgAlpha=1.0;sndDamage();
  if(G.health<=0)triggerDeath();
}

function doShoot(){
  if(G.isReloading||shootCD>0)return;
  if(G.ammo<=0){if(G.reserve>0)startReload();return;}
  G.ammo--;shootCD=0.09;updateAmmoHUD();
  muzzleT=0.07;if(muzzleFlashMesh)muzzleFlashMesh.material.opacity=1;
  fireBullet();pitch+=0.013;
  sndGunshot();
  if(G.ammo<=0&&G.reserve>0)startReload();
}

function startReload(){
  if(G.isReloading||G.ammo===G.maxAmmo||G.reserve<=0)return;
  G.isReloading=true;reloadTimer=0;
  sndReload();
  var rb=document.getElementById('reloadBar'),rf=document.getElementById('reloadFill');
  rb.style.display='block';rf.style.transition='none';rf.style.width='0%';
  setTimeout(function(){rf.style.transition='width '+(RELOAD_MS/1000)+'s linear';rf.style.width='100%';},30);
}
function finishReload(){
  var need=G.maxAmmo-G.ammo,take=Math.min(need,G.reserve);G.ammo+=take;G.reserve-=take;G.isReloading=false;
  document.getElementById('reloadBar').style.display='none';
