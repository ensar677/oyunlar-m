#planeAltLabel{position:absolute;right:52px;top:50%;transform:translateY(-50%);color:#fff;font-size:10px;letter-spacing:2px;writing-mode:vertical-rl;}
#crosshair{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:100;display:none;width:24px;height:24px;}
#crosshair::before{content:'';position:absolute;width:2px;height:24px;background:rgba(255,255,255,0.85);left:11px;top:0;}
#crosshair::after{content:'';position:absolute;width:24px;height:2px;background:rgba(255,255,255,0.85);top:11px;left:0;}
#healthWrap{position:fixed;bottom:80px;left:24px;}
#healthLabel{color:#aaa;font-size:9px;letter-spacing:3px;margin-bottom:4px;}
#healthBarBg{width:210px;height:11px;background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.2);}
#healthBar{height:100%;width:100%;background:linear-gradient(90deg,#44cc44,#88ff88);transition:width 0.2s;}
#healthNum{color:#fff;font-size:26px;font-weight:bold;margin-top:2px;}
#shieldWrap{position:fixed;bottom:58px;left:24px;}
#shieldBarBg{width:210px;height:6px;background:rgba(0,0,0,0.5);border:1px solid rgba(100,200,255,0.3);}
#shieldBar{height:100%;width:0%;background:linear-gradient(90deg,#44aaff,#88ccff);transition:width 0.2s;}
#ammoWrap{position:fixed;bottom:80px;right:24px;text-align:right;}
#ammoLabel{color:#aaa;font-size:9px;letter-spacing:3px;margin-bottom:2px;}
#ammoNum{color:#fff;font-size:40px;font-weight:bold;line-height:1;}
#ammoReserve{color:#666;font-size:14px;}
#reloadBar{width:110px;height:3px;background:rgba(255,255,255,0.1);margin-top:5px;margin-left:auto;display:none;}
#reloadFill{height:100%;width:0%;background:#f5a623;}
#weaponSlot{position:fixed;bottom:24px;right:24px;background:rgba(0,0,0,0.7);border:1px solid rgba(245,166,35,0.4);padding:8px 14px;text-align:center;min-width:130px;}
#weaponName{color:#f5a623;font-size:12px;letter-spacing:2px;font-weight:bold;}
#weaponSub{color:#888;font-size:10px;margin-top:2px;}
#aliveWrap{position:fixed;top:14px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.65);padding:5px 22px;border:1px solid rgba(255,255,255,0.1);text-align:center;}
#aliveNum{color:#f5a623;font-size:26px;font-weight:bold;line-height:1.1;}
#aliveLabel{color:#777;font-size:9px;letter-spacing:3px;}
#zoneWrap{position:fixed;top:62px;left:50%;transform:translateX(-50%);text-align:center;}
#zoneBar{width:190px;height:4px;background:rgba(0,0,0,0.5);border:1px solid rgba(0,150,255,0.3);margin:0 auto;}
#zoneFill{height:100%;width:100%;background:linear-gradient(90deg,#0088ff,#00ccff);}
#zoneLabel{color:#0088ff;font-size:9px;letter-spacing:2px;margin-top:3px;}
#minimap{position:fixed;top:14px;right:14px;width:175px;height:175px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.7);overflow:hidden;}
#minimapCanvas{width:100%;height:100%;}
#killfeed{position:fixed;top:14px;left:14px;display:flex;flex-direction:column;gap:5px;z-index:60;}
.kfe{background:rgba(0,0,0,0.75);border-left:3px solid #f5a623;padding:4px 10px;color:#fff;font-size:11px;letter-spacing:1px;animation:kfade 4s forwards;max-width:270px;}
@keyframes kfade{0%{opacity:0;transform:translateX(-8px)}6%{opacity:1;transform:translateX(0)}80%{opacity:1}100%{opacity:0}}
#dmgVignette{position:fixed;inset:0;pointer-events:none;z-index:80;}
