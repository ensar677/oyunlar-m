#hitMark::before{width:2px;height:20px;top:-10px;left:-1px;}
#hitMark::after{width:20px;height:2px;top:-1px;left:-10px;}
#scope{position:fixed;inset:0;display:none;pointer-events:none;z-index:70;}
#scopeCircle{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:290px;height:290px;border-radius:50%;box-shadow:0 0 0 9999px rgba(0,0,0,0.92);border:2px solid rgba(255,255,255,0.25);}
#scopeH{position:absolute;width:100%;height:1px;top:50%;background:rgba(255,255,255,0.35);}
#scopeV{position:absolute;height:100%;width:1px;left:50%;background:rgba(255,255,255,0.35);}
#camModeLabel{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);color:#f5a623;font-size:10px;letter-spacing:3px;background:rgba(0,0,0,0.6);padding:4px 14px;border:1px solid rgba(245,166,35,0.3);pointer-events:none;display:none;}
#dropPrompt{position:fixed;bottom:130px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.82);border:1px solid rgba(245,166,35,0.55);color:#f5a623;padding:7px 22px;font-size:11px;letter-spacing:2px;display:none;z-index:60;pointer-events:none;}
