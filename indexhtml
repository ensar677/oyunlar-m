function updateMinimap(){
  if(!mmCtx)return;var W=175,H=175,s=W/270;
  mmCtx.clearRect(0,0,W,H);mmCtx.fillStyle='rgba(8,16,8,0.9)';mmCtx.fillRect(0,0,W,H);
  mmCtx.strokeStyle='rgba(0,136,255,0.65)';mmCtx.lineWidth=1.5;mmCtx.beginPath();mmCtx.arc(W/2,H/2,G.zoneRadius*s,0,Math.PI*2);mmCtx.stroke();
  enemies.forEach(function(e){if(!e.alive)return;var ex=W/2+(e.x-pivot.position.x)*s,ey=H/2+(e.z-pivot.position.z)*s;if(ex<2||ex>W-2||ey<2||ey>H-2)return;mmCtx.fillStyle='#ff4444';mmCtx.beginPath();mmCtx.arc(ex,ey,3,0,Math.PI*2);mmCtx.fill();});
  drops.forEach(function(d){if(d.collected)return;var dx=W/2+(d.x-pivot.position.x)*s,dz=H/2+(d.z-pivot.position.z)*s;if(dx<4||dx>W-4||dz<4||dz>H-4)return;mmCtx.fillStyle=d.isAir?'#ffcc00':'#44ff88';mmCtx.beginPath();mmCtx.arc(dx,dz,4,0,Math.PI*2);mmCtx.fill();});
  mmCtx.fillStyle='#44ff44';mmCtx.beginPath();mmCtx.arc(W/2,H/2,5,0,Math.PI*2);mmCtx.fill();
  mmCtx.strokeStyle='#44ff44';mmCtx.lineWidth=2;mmCtx.beginPath();mmCtx.moveTo(W/2,H/2);mmCtx.lineTo(W/2+Math.sin(yaw)*12,H/2-Math.cos(yaw)*12);mmCtx.stroke();
}

