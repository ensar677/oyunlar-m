<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{overflow:hidden;background:#000;font-family:'Courier New',monospace;}
canvas{display:block;}
#startScreen{position:fixed;inset:0;background:linear-gradient(135deg,#0a0a0a,#1a1a2e,#0a0a0a);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:999;color:#fff;}
#startScreen h1{font-size:60px;letter-spacing:14px;color:#f5a623;font-style:italic;text-shadow:0 0 60px #f5a62388;margin-bottom:6px;}
.sub{font-size:11px;letter-spacing:8px;color:#666;margin-bottom:50px;}
#startBtn{background:linear-gradient(135deg,#f5a623,#e8821a);color:#000;border:none;padding:16px 56px;font-size:15px;letter-spacing:4px;cursor:pointer;font-family:'Courier New',monospace;font-weight:bold;text-transform:uppercase;transition:all 0.2s;}
#startBtn:hover{transform:scale(1.06);box-shadow:0 0 40px #f5a62366;}
.ctrlGrid{display:grid;grid-template-columns:1fr 1fr;gap:5px 36px;margin-top:36px;color:#444;font-size:10px;letter-spacing:1px;}
.ctrlGrid span{color:#f5a623;}
/* Uçak Ekranı */
#planeScreen{position:fixed;inset:0;background:linear-gradient(180deg,#87CEEB 0%,#b0e0ff 60%,#c8f0ff 100%);display:none;flex-direction:column;align-items:center;justify-content:center;z-index:998;overflow:hidden;}
#planeScreen canvas{position:absolute;top:0;left:0;}
#jumpPrompt{position:absolute;bottom:120px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.75);border:2px solid #f5a623;color:#f5a623;padding:14px 36px;font-size:16px;letter-spacing:4px;text-align:center;pointer-events:none;animation:pulsePrompt 1s infinite;}
@keyframes pulsePrompt{0%,100%{opacity:1;}50%{opacity:0.5;}}
#planeAltBar{position:absolute;right:30px;top:50%;transform:translateY(-50%);width:14px;height:200px;background:rgba(0,0,0,0.4);border:1px solid rgba(255,255,255,0.3);}
